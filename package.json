{
  "name": "heif2jpeg",
  "version": "0.1.2",
  "description": "Fast HEIC/HEIF to JPEG converter — native, zero runtime dependencies",
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "napi": {
    "name": "heif2jpeg",
    "package": {
      "name": "@heif2jpeg/heif2jpeg"
    },
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node --test test/test.mjs",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  },
  "license": "MIT",
  "engines": {
    "node": ">= 18"
  },
  "optionalDependencies": {
    "@heif2jpeg/heif2jpeg-win32-x64-msvc": "0.1.2",
    "@heif2jpeg/heif2jpeg-win32-arm64-msvc": "0.1.2",
    "@heif2jpeg/heif2jpeg-darwin-x64": "0.1.2",
    "@heif2jpeg/heif2jpeg-darwin-arm64": "0.1.2",
    "@heif2jpeg/heif2jpeg-linux-x64-gnu": "0.1.2",
    "@heif2jpeg/heif2jpeg-linux-arm64-gnu": "0.1.2"
  }
}
